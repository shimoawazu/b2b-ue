{
  "definitions": [
    {
      "title": "List",
      "id": "list",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "List",
              "model": "list",
              "rootPath": "/en/news",
              "sortBy": "alphabetical",
              "showDescription": false,
              "showImage": false,
              "showDate": false,
              "limit": 0,
              "paginate": false,
              "pageSize": 5,
              "urlState": false,
              "listStyle": "card"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "list",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "rootPath",
          "label": "Root Path",
          "description": "EDS path whose children to list, e.g. /en/news. A matching query-index must exist at {rootPath}/query-index.json."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "sortBy",
          "label": "Sort By",
          "options": [
            { "name": "Alphabetical", "value": "alphabetical" },
            { "name": "Last Modified (newest first)", "value": "lastModified" },
            { "name": "List Order (numeric)", "value": "listOrder" }
          ]
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "showDescription",
          "label": "Show Description",
          "value": false
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "showImage",
          "label": "Show Image",
          "value": false
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "showDate",
          "label": "Show Date",
          "value": false
        },
        {
          "component": "number",
          "valueType": "number",
          "name": "limit",
          "label": "Max Items",
          "description": "Maximum number of items to show. Set to 0 for no limit.",
          "value": 0
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "paginate",
          "label": "Enable Pagination",
          "description": "Show items across multiple pages instead of all at once.",
          "value": false
        },
        {
          "component": "number",
          "valueType": "number",
          "name": "pageSize",
          "label": "Items Per Page",
          "description": "Number of items per page (e.g. 5 or 10). Ignored when pagination is disabled.",
          "value": 5
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "urlState",
          "label": "Persist Page in URL",
          "description": "Store the current page in ?page=N so links are shareable and back/forward works. Only applies when pagination is enabled.",
          "value": false
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "listStyle",
          "label": "List Style",
          "description": "Visual style of the list. Card: image grid. Small/Medium: compact vertical rows.",
          "options": [
            { "name": "Card", "value": "card" },
            { "name": "Small", "value": "small" },
            { "name": "Medium", "value": "medium" },
            { "name": "News Featured", "value": "news-featured" },
            { "name": "Related Articles", "value": "related" },
            { "name": "Footer Nav", "value": "footer-nav" }
          ],
          "value": "card"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "readMoreText",
          "label": "Read More Label",
          "description": "Text for the read-more link on news-featured cards. Leave blank to hide. E.g. 'Read more' or 'Continue reading'."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "heading",
          "label": "Heading",
          "description": "Column heading shown above the list (e.g. PRODUCTS). Used by footer-nav style."
        }
      ]
    }
  ],
  "filters": []
}
