<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="Home"
      jcr:description="Lumina Noventis — Precision Optics. Advanced Imaging."
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Hero B2B Section -->
      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="PRECISION OPTICS · ADVANCED IMAGING"
              header="Measure What Matters Most"
              description="&lt;p>From aerospace optical systems to medical imaging platforms — Lumina Noventis delivers the photonic precision your most demanding applications require.&lt;/p>"
              cta1Text="Explore Products"
              cta1Link="/en/products"
              cta2Text="View Solutions"
              cta2Link="/en/solutions"
              stat1Value="40+"
              stat1Label="Years Experience"
              stat2Value="120+"
              stat2Label="Countries Served"
              stat3Value="ISO 17025"
              stat3Label="Certified Calibration"/>
      </section>

      <!-- Solutions Grid Section -->
      <section_solutions jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="highlight">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="INDUSTRY SOLUTIONS"
               heading="Engineered for Your Industry"
               subtitle="&lt;p>From semiconductor fabrication to pharmaceutical compliance, our measurement solutions adapt to the precision demands of your sector.&lt;/p>"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Precision Manufacturing&lt;/h3>&#xa;&lt;p>Dimensional metrology for tight-tolerance machined &amp; formed parts&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="hex-tolerance"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Medical Device Mfg.&lt;/h3>&#xa;&lt;p>FDA 21 CFR Part 11 compliance &amp; GMP validation&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="clipboard"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Life Sciences &amp;amp; R&amp;amp;D&lt;/h3>&#xa;&lt;p>Laboratory-grade metrology for research-grade data&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="waveform"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Industrial Print&lt;/h3>&#xa;&lt;p>Spectral measurement for color consistency &amp; registration&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="monitor"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Label &amp;amp; Packaging&lt;/h3>&#xa;&lt;p>Inline QC for high-speed label &amp; flexible packaging lines&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="lock"/>
          <item6 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Additive Manufacturing&lt;/h3>&#xa;&lt;p>Dimensional verification for 3D printed &amp; AM parts&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="cube"/>
        </cards>
        <cta_link jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="CTA Link"
               model="cta-link"
               linkText="View All Solutions"
               linkUrl="/en/solutions"/>
      </section_solutions>

      <!-- Why Engineers Choose Lumina Noventis — Feature Split Section -->
      <section_why_engineers jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="WHY ENGINEERS CHOOSE US"
               heading="Built for the Demands of Modern Precision Engineering"
               subtitle="&lt;p>From sub-micron metrology to global service infrastructure — every Lumina Noventis instrument is engineered to the exacting standards your application demands.&lt;/p>"
               ctaText="Explore Our Technology"
               ctaLink="/en/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>OIML-Certified Traceability&lt;/h3>&lt;p>Every instrument traceable to international standards via ISO 17025-accredited calibration labs&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="clock"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Sub-Micron Accuracy&lt;/h3>&lt;p>Optical systems calibrated to 0.05 µm resolution for the tightest dimensional tolerances in semiconductor and aerospace&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="check-shield"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Industry 4.0 / IIoT Ready&lt;/h3>&lt;p>Real-time data streaming and OPC-UA connectivity for seamless MES and ERP integration&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="bar-chart"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Global Service Network&lt;/h3>&lt;p>42 service centers across 6 continents with guaranteed 48-hour response for critical applications&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="globe"/>
        </cards>
      </section_why_engineers>

      <!-- News Section -->
      <section_news jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="LATEST NEWS"
               heading="From the Lab &amp; Field"
               ctaText="View All News"
               ctaLink="/en/news"
               style="news-inline"/>
        <list jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="List"
              model="list"
              rootPath="/en/news"
              sortBy="listOrder"
              showDescription="true"
              showImage="true"
              showDate="true"
              limit="3"
              paginate="false"
              pageSize="5"
              urlState="false"
              listStyle="news-featured"
              readMoreText="Read more"/>
      </section_news>


      <!-- CTA / Contact Section -->
      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_cta jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="READY TO GET STARTED?"
              header="Talk to a Metrology Application Engineer"
              description="&lt;p>Tell us your measurement challenge. Our engineers will recommend the right instrument, calibration protocol, and integration path for your process.&lt;/p>"
              cta1Text="Request a Demo"
              cta1Link="/en/contact"
              cta2Text="Download Brochure"
              cta2Link="/en/resources/brochure"
              stat1Value="98.7%"
              stat1Label="System Uptime SLA"
              stat2Value="4h"
              stat2Label="Average Response Time"
              stat3Value="42"
              stat3Label="Global Service Centers"
              variant="cta"/>
      </section_cta>

    </root>
  </jcr:content>
  <nav/>
  <footer/>
  <search/>
  <products/>
  <solutions/>
  <about/>
  <news/>
</jcr:root>
