<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="Inicio"
      jcr:description="Lumina Noventis — Óptica de Precisión. Imagen Avanzada."
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Hero B2B Section -->
      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="ÓPTICA DE PRECISIÓN · IMAGEN AVANZADA"
              header="Mide lo que más importa"
              description="&lt;p>Desde sistemas ópticos aeroespaciales hasta plataformas de imagen médica, Lumina Noventis ofrece la precisión fotónica que sus aplicaciones más exigentes requieren.&lt;/p>"
              cta1Text="Explorar productos"
              cta1Link="/es/products"
              cta2Text="Ver soluciones"
              cta2Link="/es/solutions"
              stat1Value="40+"
              stat1Label="Años de experiencia"
              stat2Value="120+"
              stat2Label="Países atendidos"
              stat3Value="ISO 17025"
              stat3Label="Calibración certificada"/>
      </section>

      <!-- Solutions Grid Section -->
      <section_solutions jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="highlight">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="SOLUCIONES INDUSTRIALES"
               heading="Diseñado para su industria"
               subtitle="&lt;p>Desde la fabricación de semiconductores hasta el cumplimiento farmacéutico, nuestras soluciones de medición se adaptan a las exigencias de precisión de su sector.&lt;/p>"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Fabricación de precisión&lt;/h3>&#xa;&lt;p>Metrología dimensional para piezas mecanizadas y conformadas de tolerancia estrecha&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="hex-tolerance"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Fabricación de dispositivos médicos&lt;/h3>&#xa;&lt;p>Cumplimiento FDA 21 CFR Parte 11 y validación GMP&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="clipboard"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Ciencias de la vida e I+D&lt;/h3>&#xa;&lt;p>Metrología de grado laboratorio para datos de grado investigación&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="waveform"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Impresión industrial&lt;/h3>&#xa;&lt;p>Medición espectral para consistencia de color y registro&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="monitor"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Etiquetas y envases&lt;/h3>&#xa;&lt;p>Control de calidad en línea para líneas de etiquetado y envasado flexible de alta velocidad&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="lock"/>
          <item6 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Fabricación aditiva&lt;/h3>&#xa;&lt;p>Verificación dimensional para piezas impresas en 3D y AM&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="cube"/>
        </cards>
        <cta_link jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="CTA Link"
               model="cta-link"
               linkText="Ver todas las soluciones"
               linkUrl="/es/solutions"/>
      </section_solutions>

      <!-- Why Engineers Choose Lumina Noventis -->
      <section_why_engineers jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="POR QUÉ LOS INGENIEROS ELIGEN LUMINA NOVENTIS"
               heading="Por qué los ingenieros eligen Lumina Noventis"
               subtitle="&lt;p>Cuatro décadas de innovación en metrología integradas en cada instrumento que enviamos.&lt;/p>"
               ctaText="Conozca nuestra tecnología"
               ctaLink="/es/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Trazabilidad OIML e ISO&lt;/h3>&#xa;&lt;p>Cada certificado de calibración es trazable a los institutos nacionales de metrología.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="clock"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Precisión submicrónica&lt;/h3>&#xa;&lt;p>Incertidumbre de medición inferior a 0,1 µm en toda la gama de instrumentos dimensionales.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="check-shield"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>IIoT / Industria 4.0&lt;/h3>&#xa;&lt;p>Salida OPC-UA, Profinet y REST API para integración perfecta con MES y SCADA.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="bar-chart"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>Red de servicio global&lt;/h3>&#xa;&lt;p>42 centros de servicio en 30 países — SLA de disponibilidad del 98,7% para sistemas críticos.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="globe"/>
        </cards>
      </section_why_engineers>

      <!-- News Section -->
      <section_news jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="ÚLTIMAS NOTICIAS"
               heading="Desde el laboratorio y el campo"
               ctaText="Ver todas las noticias"
               ctaLink="/es/news"
               style="news-inline"/>
        <list jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="List"
              model="list"
              rootPath="/es/news"
              sortBy="listOrder"
              showDescription="true"
              showImage="true"
              showDate="true"
              limit="3"
              paginate="false"
              pageSize="5"
              urlState="false"
              listStyle="news-featured"
              readMoreText="Leer más"/>
      </section_news>

      <!-- CTA / Contact Section -->
      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_cta jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="¿LISTO PARA COMENZAR?"
              header="Hable con un ingeniero de aplicaciones de metrología"
              description="&lt;p>Cuéntenos su desafío de medición. Nuestros ingenieros recomendarán el instrumento adecuado, el protocolo de calibración y la ruta de integración para su proceso.&lt;/p>"
              cta1Text="Solicitar demo"
              cta1Link="/es/contact"
              cta2Text="Descargar folleto"
              cta2Link="/es/resources/brochure"
              stat1Value="98,7%"
              stat1Label="SLA de disponibilidad del sistema"
              stat2Value="4h"
              stat2Label="Tiempo de respuesta promedio"
              stat3Value="42"
              stat3Label="Centros de servicio globales"
              variant="cta"/>
      </section_cta>

    </root>
  </jcr:content>
  <nav/>
  <footer/>
  <search/>
  <products/>
  <solutions/>
  <about/>
  <news/>
</jcr:root>
