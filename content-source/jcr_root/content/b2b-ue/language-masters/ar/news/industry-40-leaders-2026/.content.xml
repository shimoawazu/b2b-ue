      jcr:primaryType="cq:PageContent"
      jcr:title="Lumina Noventis تُدرَج في مؤشر قادة الصناعة 4.0 لعام 2026"
      jcr:description="للسنة الثالثة على التوالي، تحظى Lumina Noventis بالتقدير بوصفها من بين أفضل 100 مُمكِّن لصناعة 4.0 في قطاع التصنيع الدقيق العالمي."
      cq:lastModified="2026-01-14T00:00:00.000+00:00"
      cq:tags="[b2b-ue:news-category/company]"
      category="COMPANY"
      listOrder="3"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Breadcrumb + Tag -->
