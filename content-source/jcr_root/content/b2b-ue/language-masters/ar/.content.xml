<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="الرئيسية"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Hero B2B Section -->
      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="بصريات دقيقة · تصوير متقدم"
              header="قِس ما يهم حقًا"
              description="&lt;p&gt;من الأنظمة البصرية الخاصة بالطيران والفضاء إلى منصات التصوير الطبي، تقدم Lumina Noventis الدقة الفوتونية التي تتطلبها تطبيقاتكم الأكثر تعقيدًا.&lt;/p&gt;"
              cta1Text="استكشاف المنتجات"
              cta1Link="/ar/products"
              cta2Text="عرض الحلول"
              cta2Link="/ar/solutions"
              stat1Value="+40"
              stat1Label="سنة من الخبرة"
              stat2Value="+120"
              stat2Label="دولة نخدمها"
              stat3Value="ISO 17025"
              stat3Label="معايرة معتمدة"/>
      </section>

      <!-- Solutions Grid Section -->
      <section_solutions jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="highlight">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="حلول الصناعات"
               heading="مصممة لقطاعكم الصناعي"
               subtitle="&lt;p&gt;من تصنيع أشباه الموصلات إلى الامتثال الدوائي، تتكيف حلول القياس لدينا مع متطلبات الدقة في قطاعكم.&lt;/p&gt;"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;التصنيع الدقيق&lt;/h3&gt;&#xa;&lt;p&gt;قياسات بعدية للأجزاء المشغولة والمشكلة ذات السماحات الضيقة&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="hex-tolerance"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;تصنيع الأجهزة الطبية&lt;/h3&gt;&#xa;&lt;p&gt;الامتثال لمتطلبات FDA 21 CFR Part 11 والتحقق وفق GMP&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="clipboard"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;علوم الحياة والبحث والتطوير&lt;/h3&gt;&#xa;&lt;p&gt;قياسات بمستوى مختبري للحصول على بيانات بحثية موثوقة&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="waveform"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;الطباعة الصناعية&lt;/h3&gt;&#xa;&lt;p&gt;قياس طيفي لضمان ثبات الألوان ودقة التسجيل&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="monitor"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;الملصقات والتغليف&lt;/h3&gt;&#xa;&lt;p&gt;ضبط جودة آني لخطوط الملصقات والتغليف المرن عالية السرعة&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="lock"/>
          <item6 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;التصنيع الإضافي&lt;/h3&gt;&#xa;&lt;p&gt;تحقق بعدي لأجزاء الطباعة ثلاثية الأبعاد وأجزاء التصنيع الإضافي&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="cube"/>
        </cards>
        <cta_link jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="CTA Link"
               model="cta-link"
               linkText="عرض جميع الحلول"
               linkUrl="/ar/solutions"/>
      </section_solutions>

      <!-- Why Engineers Choose Lumina Noventis -->
      <section_why_engineers jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="لماذا يختار المهندسون LUMINA NOVENTIS"
               heading="لماذا يختار المهندسون Lumina Noventis"
               subtitle="&lt;p&gt;أربعة عقود من الابتكار في علم القياس، مدمجة في كل جهاز نقوم بشحنه.&lt;/p&gt;"
               ctaText="تعرّف على تقنيتنا"
               ctaLink="/ar/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;إمكانية التتبع وفق OIML وISO&lt;/h3&gt;&#xa;&lt;p&gt;كل شهادة معايرة قابلة للتتبع إلى المعاهد الوطنية للقياس.&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="clock"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;دقة دون الميكرون&lt;/h3&gt;&#xa;&lt;p&gt;لا تتجاوز اليقينية القياس 0.1 ميكرومتر عبر مجموعتنا الكاملة من أجهزة القياس البعدي.&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="check-shield"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;IIoT / الصناعة 4.0&lt;/h3&gt;&#xa;&lt;p&gt;مخرجات OPC-UA وProfinet وREST API لدمج سلس مع MES وSCADA.&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="bar-chart"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;شبكة خدمة عالمية&lt;/h3&gt;&#xa;&lt;p&gt;42 مركز خدمة في 30 دولة مع نسبة جاهزية وفق SLA تبلغ 98.7% للأنظمة الحرجة.&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="globe"/>
        </cards>
      </section_why_engineers>

      <!-- News Section -->
      <section_news jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="أحدث الأخبار"
               heading="من المختبر والميدان"
               ctaText="عرض جميع الأخبار"
               ctaLink="/ar/news"
               style="news-inline"/>
        <list jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="List"
              model="list"
              rootPath="/ar/news"
              sortBy="listOrder"
              showDescription="true"
              showImage="true"
              showDate="true"
              limit="3"
              paginate="false"
              pageSize="5"
              urlState="false"
              listStyle="news-featured"
              readMoreText="اقرأ المزيد"/>
      </section_news>

      <!-- CTA / Contact Section -->
      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_cta jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="هل أنتم جاهزون للبدء؟"
              header="تحدثوا مع مهندس تطبيقات القياس"
              description="&lt;p&gt;أخبرونا بتحدي القياس لديكم. سيقترح مهندسونا الجهاز المناسب وبروتوكول المعايرة ومسار التكامل الملائم لعمليتكم.&lt;/p&gt;"
              cta1Text="اطلبوا عرضًا تجريبيًا"
              cta1Link="/ar/contact"
              cta2Text="حمّلوا الكتيب"
              cta2Link="/ar/resources/brochure"
              stat1Value="98.7%"
              stat1Label="جاهزية النظام وفق SLA"
              stat2Value="4 ساعات"
              stat2Label="متوسط زمن الاستجابة"
              stat3Value="42"
              stat3Label="مركز خدمة عالمي"
              variant="cta"/>
      </section_cta>

    </root>
  </jcr:content>
  <nav/>
  <footer/>
  <search/>
  <products/>
  <solutions/>
  <about/>
  <news/>
</jcr:root>
