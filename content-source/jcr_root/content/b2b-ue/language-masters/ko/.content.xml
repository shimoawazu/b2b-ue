<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="홈"
      jcr:description="Lumina Noventis — 정밀 광학 · 첨단 이미징"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Hero B2B Section -->
      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="정밀 광학 · 첨단 이미징"
              header="가장 중요한 것을 정밀하게 측정합니다"
              description="&lt;p>항공우주 광학 시스템부터 의료 영상 플랫폼까지, Lumina Noventis는 가장 까다로운 적용 분야에 필요한 광학 정밀도를 제공합니다.&lt;/p>"
              cta1Text="제품 보기"
              cta1Link="/ko/products"
              cta2Text="솔루션 보기"
              cta2Link="/ko/solutions"
              stat1Value="40+"
              stat1Label="년의 경험"
              stat2Value="120+"
              stat2Label="서비스 제공 국가"
              stat3Value="ISO 17025"
              stat3Label="인증 교정"/>
      </section>

      <!-- Solutions Grid Section -->
      <section_solutions jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="highlight">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="산업별 솔루션"
               heading="귀사의 산업을 위해 설계되었습니다"
               subtitle="&lt;p>반도체 제조부터 제약 규정 준수까지, 당사의 측정 솔루션은 각 산업의 정밀 요구사항에 맞춰 적용됩니다.&lt;/p>"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>정밀 제조&lt;/h3>&#xa;&lt;p>엄격한 공차를 요구하는 가공 및 성형 부품을 위한 치수 계측&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="hex-tolerance"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>의료기기 제조&lt;/h3>&#xa;&lt;p>FDA 21 CFR Part 11 준수 및 GMP 검증 지원&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="clipboard"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>생명과학 및 연구개발&lt;/h3>&#xa;&lt;p>연구급 데이터 확보를 위한 실험실급 계측&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="waveform"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>산업용 인쇄&lt;/h3>&#xa;&lt;p>색 일관성과 정합 제어를 위한 분광 측정&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="monitor"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>라벨 및 패키징&lt;/h3>&#xa;&lt;p>고속 라벨 및 연포장 라인을 위한 인라인 품질 관리&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="lock"/>
          <item6 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>적층 제조&lt;/h3>&#xa;&lt;p>3D 프린팅 및 AM 부품의 치수 검증&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="cube"/>
        </cards>
        <cta_link jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="CTA Link"
               model="cta-link"
               linkText="모든 솔루션 보기"
               linkUrl="/ko/solutions"/>
      </section_solutions>

      <!-- Why Engineers Choose Lumina Noventis -->
      <section_why_engineers jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="왜 엔지니어들은 LUMINA NOVENTIS를 선택하는가"
               heading="왜 엔지니어들은 Lumina Noventis를 선택하는가"
               subtitle="&lt;p>40년에 걸친 계측 혁신이 우리가 출하하는 모든 장비에 담겨 있습니다.&lt;/p>"
               ctaText="기술에 대해 더 알아보기"
               ctaLink="/ko/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>OIML 및 ISO 추적 가능&lt;/h3>&#xa;&lt;p>모든 교정 성적서는 국가 계량 표준 기관까지 추적 가능합니다.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="clock"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>서브마이크론 정확도&lt;/h3>&#xa;&lt;p>당사의 치수 측정 장비 전반에서 0.1µm 미만의 측정 불확도를 제공합니다.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="check-shield"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>IIoT / Industry 4.0&lt;/h3>&#xa;&lt;p>MES 및 SCADA와의 원활한 연동을 위해 OPC-UA, Profinet, REST API 출력을 지원합니다.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="bar-chart"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>글로벌 서비스 네트워크&lt;/h3>&#xa;&lt;p>30개국 42개 서비스 센터를 운영하며, 핵심 시스템 SLA 가동률은 98.7%입니다.&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="globe"/>
        </cards>
      </section_why_engineers>

      <!-- News Section -->
      <section_news jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="최신 뉴스"
               heading="연구실과 현장에서"
               ctaText="모든 뉴스 보기"
               ctaLink="/ko/news"
               style="news-inline"/>
        <list jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="List"
              model="list"
              rootPath="/ko/news"
              sortBy="listOrder"
              showDescription="true"
              showImage="true"
              showDate="true"
              limit="3"
              paginate="false"
              pageSize="5"
              urlState="false"
              listStyle="news-featured"
              readMoreText="자세히 보기"/>
      </section_news>

      <!-- CTA / Contact Section -->
      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_cta jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="시작할 준비가 되셨나요?"
              header="계측 애플리케이션 엔지니어와 상담하세요"
              description="&lt;p>귀사의 측정 과제를 알려주세요. 당사 엔지니어가 귀사의 공정에 맞는 장비, 교정 프로토콜, 통합 경로를 제안해 드립니다.&lt;/p>"
              cta1Text="데모 요청"
              cta1Link="/ko/contact"
              cta2Text="브로셔 다운로드"
              cta2Link="/ko/resources/brochure"
              stat1Value="98.7%"
              stat1Label="시스템 가동률 SLA"
              stat2Value="4시간"
              stat2Label="평균 응답 시간"
              stat3Value="42"
              stat3Label="글로벌 서비스 센터"
              variant="cta"/>
      </section_cta>

    </root>
  </jcr:content>
  <nav/>
  <footer/>
  <search/>
  <products/>
  <solutions/>
  <about/>
  <news/>
</jcr:root>
