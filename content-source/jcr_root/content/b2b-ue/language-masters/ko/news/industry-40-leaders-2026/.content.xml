      jcr:title="Lumina Noventis, 2026년 인더스트리 4.0 리더스 인덱스 선정"
      jcr:description="Lumina Noventis가 3년 연속으로 글로벌 정밀 제조 분야 상위 100대 인더스트리 4.0 인에이블러로 인정받았습니다."
      cq:lastModified="2026-01-14T00:00:00.000+00:00"
      cq:tags="[b2b-ue:news-category/company]"
      category="COMPANY"
      listOrder="3"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

