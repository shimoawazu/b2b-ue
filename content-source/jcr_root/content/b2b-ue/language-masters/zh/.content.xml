<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="首页"
      jcr:description="Lumina Noventis — 精密光学 · 先进成像"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Hero B2B Section -->
      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="精密光学 · 先进成像"
              header="测量真正重要的事物"
              description="&lt;p>从航空航天光学系统到医疗成像平台，Lumina Noventis 为最严苛的应用提供所需的光子级精度。&lt;/p>"
              cta1Text="查看产品"
              cta1Link="/zh/products"
              cta2Text="查看解决方案"
              cta2Link="/zh/solutions"
              stat1Value="40+"
              stat1Label="年行业经验"
              stat2Value="120+"
              stat2Label="服务国家"
              stat3Value="ISO 17025"
              stat3Label="认证校准"/>
      </section>

      <!-- Solutions Grid Section -->
      <section_solutions jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="highlight">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="行业解决方案"
               heading="为您的行业而打造"
               subtitle="&lt;p>从半导体制造到制药合规，我们的测量解决方案能够适应您所在行业对精度的严格要求。&lt;/p>"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>精密制造&lt;/h3>&#xa;&lt;p>面向高公差机加工件和成形件的尺寸计量&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="hex-tolerance"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>医疗器械制造&lt;/h3>&#xa;&lt;p>支持 FDA 21 CFR Part 11 合规与 GMP 验证&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="clipboard"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>生命科学与研发&lt;/h3>&#xa;&lt;p>为研究级数据提供实验室级计量能力&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="waveform"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>工业印刷&lt;/h3>&#xa;&lt;p>用于色彩一致性与套准控制的光谱测量&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="monitor"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>标签与包装&lt;/h3>&#xa;&lt;p>适用于高速标签与柔性包装产线的在线质量控制&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="lock"/>
          <item6 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>增材制造&lt;/h3>&#xa;&lt;p>用于 3D 打印及增材制造零件的尺寸验证&lt;/p>"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="cube"/>
        </cards>
        <cta_link jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="CTA Link"
               model="cta-link"
               linkText="查看全部解决方案"
               linkUrl="/zh/solutions"/>
      </section_solutions>

      <!-- Why Engineers Choose Lumina Noventis -->
      <section_why_engineers jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="为什么工程师选择 LUMINA NOVENTIS"
               heading="为什么工程师选择 Lumina Noventis"
               subtitle="&lt;p>四十年的计量创新，融入我们交付的每一台仪器。&lt;/p>"
               ctaText="了解我们的技术"
               ctaLink="/zh/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>OIML 与 ISO 可追溯&lt;/h3>&#xa;&lt;p>每份校准证书都可追溯至国家计量机构。&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="clock"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>亚微米级精度&lt;/h3>&#xa;&lt;p>在我们的尺寸测量仪器系列中，测量不确定度低于 0.1 µm。&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="check-shield"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>IIoT / 工业 4.0&lt;/h3>&#xa;&lt;p>支持 OPC-UA、Profinet 和 REST API 输出，实现与 MES 和 SCADA 的无缝集成。&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="bar-chart"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3>全球服务网络&lt;/h3>&#xa;&lt;p>在 30 个国家设有 42 个服务中心，关键系统 SLA 正常运行时间达 98.7%。&lt;/p>"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="globe"/>
        </cards>
      </section_why_engineers>

      <!-- News Section -->
      <section_news jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="最新新闻"
               heading="来自实验室与现场"
               ctaText="查看全部新闻"
               ctaLink="/zh/news"
               style="news-inline"/>
        <list jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="List"
              model="list"
              rootPath="/zh/news"
              sortBy="listOrder"
              showDescription="true"
              showImage="true"
              showDate="true"
              limit="3"
              paginate="false"
              pageSize="5"
              urlState="false"
              listStyle="news-featured"
              readMoreText="阅读更多"/>
      </section_news>

      <!-- CTA / Contact Section -->
      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_cta jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="准备开始了吗？"
              header="与计量应用工程师沟通"
              description="&lt;p>告诉我们您的测量挑战。我们的工程师将为您的工艺推荐合适的仪器、校准方案和集成路径。&lt;/p>"
              cta1Text="申请演示"
              cta1Link="/zh/contact"
              cta2Text="下载宣传册"
              cta2Link="/zh/resources/brochure"
              stat1Value="98.7%"
              stat1Label="系统正常运行 SLA"
              stat2Value="4小时"
              stat2Label="平均响应时间"
              stat3Value="42"
              stat3Label="全球服务中心"
              variant="cta"/>
      </section_cta>

    </root>
  </jcr:content>
  <nav/>
  <footer/>
  <search/>
  <products/>
  <solutions/>
  <about/>
  <news/>
</jcr:root>
