<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="ホーム"
      jcr:description="Lumina Noventis — 精密光学・先端イメージング"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <!-- Hero B2B Section -->
      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="精密光学 · 先端イメージング"
              header="重要なものを、正確に測る"
              description="&lt;p&gt;航空宇宙用光学システムから医療イメージングプラットフォームまで、Lumina Noventisは最も要求の厳しい用途に対応するフォトニック精度を提供します。&lt;/p&gt;"
              cta1Text="製品を見る"
              cta1Link="/ja/products"
              cta2Text="ソリューションを見る"
              cta2Link="/ja/solutions"
              stat1Value="40年以上"
              stat1Label="導入実績"
              stat2Value="120か国以上"
              stat2Label="サービス提供地域"
              stat3Value="ISO 17025"
              stat3Label="認証校正"/>
      </section>

      <!-- Solutions Grid Section -->
      <section_solutions jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="highlight">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="業界ソリューション"
               heading="業界ごとに最適化された設計"
               subtitle="&lt;p&gt;半導体製造から医薬品コンプライアンスまで、当社の測定ソリューションは各業界の精度要求に対応します。&lt;/p&gt;"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;精密製造&lt;/h3&gt;&#xa;&lt;p&gt;高精度加工部品および成形部品の寸法計測&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="hex-tolerance"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;医療機器製造&lt;/h3&gt;&#xa;&lt;p&gt;FDA 21 CFR Part 11対応およびGMPバリデーション&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="clipboard"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;ライフサイエンス・研究開発&lt;/h3&gt;&#xa;&lt;p&gt;研究品質データのためのラボグレード計測&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="waveform"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;産業印刷&lt;/h3&gt;&#xa;&lt;p&gt;色一貫性と見当精度のための分光測定&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="monitor"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;ラベル・パッケージング&lt;/h3&gt;&#xa;&lt;p&gt;高速ラベルおよび軟包装ライン向けインライン品質管理&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="lock"/>
          <item6 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;アディティブ製造&lt;/h3&gt;&#xa;&lt;p&gt;3Dプリント部品およびAM部品の寸法検証&lt;/p&gt;"
                 cardstyle="solution-tile"
                 ctastyle=""
                 icon="cube"/>
        </cards>
        <cta_link jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="CTA Link"
               model="cta-link"
               linkText="すべてのソリューションを見る"
               linkUrl="/ja/solutions"/>
      </section_solutions>

      <!-- Why Engineers Choose Lumina Noventis -->
      <section_why_engineers jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="LUMINA NOVENTISが選ばれる理由"
               heading="エンジニアがLumina Noventisを選ぶ理由"
               subtitle="&lt;p&gt;40年にわたる計測技術の革新を、出荷するすべての機器に組み込んでいます。&lt;/p&gt;"
               ctaText="当社の技術について詳しく見る"
               ctaLink="/ja/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;OIML・ISOトレーサブル&lt;/h3&gt;&lt;p&gt;すべての校正証明書は国家計量標準機関へトレーサブルです。&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="clock"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;サブミクロン精度&lt;/h3&gt;&lt;p&gt;寸法測定機器ライン全体で0.1µm未満の測定不確かさを実現。&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="check-shield"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;IIoT / Industry 4.0&lt;/h3&gt;&lt;p&gt;MESおよびSCADAとのシームレスな統合のため、OPC-UA、Profinet、REST API出力に対応。&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="bar-chart"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 text="&lt;h3&gt;グローバルサービスネットワーク&lt;/h3&gt;&lt;p&gt;30か国42サービス拠点。重要システム向け稼働率SLA 98.7%。&lt;/p&gt;"
                 cardstyle="feature-tile"
                 ctastyle=""
                 icon="globe"/>
        </cards>
      </section_why_engineers>

      <!-- News Section -->
      <section_news jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="最新ニュース"
               heading="研究開発と現場から"
               ctaText="すべてのニュースを見る"
               ctaLink="/ja/news"
               style="news-inline"/>
        <list jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="List"
              model="list"
              rootPath="/ja/news"
              sortBy="listOrder"
              showDescription="true"
              showImage="true"
              showDate="true"
              limit="3"
              paginate="false"
              pageSize="5"
              urlState="false"
              listStyle="news-featured"
              readMoreText="続きを読む"/>
      </section_news>

      <!-- CTA / Contact Section -->
      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_cta jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/solutions-medical-preview.jpg"
              preheader="導入をご検討ですか？"
              header="計測アプリケーションエンジニアに相談"
              description="&lt;p&gt;測定に関する課題をお聞かせください。最適な機器、校正プロトコル、そしてお客様の工程に適した統合方法をご提案します。&lt;/p&gt;"
              cta1Text="デモを依頼"
              cta1Link="/ja/contact"
              cta2Text="会社案内をダウンロード"
              cta2Link="/ja/resources/brochure"
              stat1Value="98.7%"
              stat1Label="システム稼働率SLA"
              stat2Value="4時間"
              stat2Label="平均応答時間"
              stat3Value="42"
              stat3Label="グローバルサービス拠点"
              variant="cta"/>
      </section_cta>

    </root>
  </jcr:content>
  <nav/>
  <footer/>
  <search/>
  <products/>
  <solutions/>
  <about/>
  <news/>
</jcr:root>
