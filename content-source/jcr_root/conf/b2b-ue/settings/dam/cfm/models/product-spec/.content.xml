<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:dam="http://www.day.com/dam/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Template"
    allowedPaths="[/content/dam/b2b-ue(/.*)?]"
    ranking="{Long}100">
    <jcr:content
        cq:isDelivered="{Boolean}false"
        cq:scaffolding="/conf/b2b-ue/settings/dam/cfm/models/product-spec/jcr:content/model"
        cq:templateType="/libs/settings/dam/cfm/model-types/fragment"
        jcr:mixinTypes="[cq:ReplicationStatus2]"
        jcr:primaryType="cq:PageContent"
        jcr:title="Product Spec"
        sling:resourceSuperType="dam/cfm/models/console/components/data/entity"
        sling:resourceType="dam/cfm/models/console/components/data/entity/default"
        isLocked="{Boolean}false"
        status="enabled">
        <metadata jcr:primaryType="nt:unstructured"/>
        <model
            cq:targetPath="/content/dam/b2b-ue"
            jcr:primaryType="cq:PageContent"
            jcr:title="Product Spec"
            sling:resourceType="wcm/scaffolding/components/scaffolding"
            dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
            maxGeneratedOrder="12">
            <cq:dialog
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/gui/components/authoring/dialog">
                <content
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                    <items
                        jcr:primaryType="nt:unstructured"
                        maxGeneratedOrder="12">
                        <field-productName
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Product Name"
                            listOrder="1"
                            maxlength="255"
                            metaType="text-single"
                            name="productName"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-productName>
                        <field-series
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Series"
                            listOrder="2"
                            maxlength="255"
                            metaType="text-single"
                            name="series"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-series>
                        <field-category
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Category"
                            listOrder="3"
                            maxlength="255"
                            metaType="text-single"
                            name="category"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-category>
                        <field-shortDescription
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="shortDescription"
                            checked="false"
                            default-mime-type="text/plain"
                            fieldLabel="Short Description"
                            listOrder="4"
                            metaType="text-multi"
                            name="shortDescription"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-shortDescription>
                        <field-heroImage
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/contentreference"
                            fieldLabel="Hero Image"
                            filter="hierarchy"
                            listOrder="5"
                            metaType="reference"
                            name="heroImage"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            rootPath="/content/dam"
                            showEmptyInReadOnly="true"
                            showThumbnail="false"
                            valueType="string/reference">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                thumbnail-validation="cfm.validation.thumbnail.show"/>
                        </field-heroImage>
                        <field-measurementUncertainty
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Measurement Uncertainty"
                            listOrder="6"
                            maxlength="255"
                            metaType="text-single"
                            name="measurementUncertainty"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-measurementUncertainty>
                        <field-protectionRating
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Protection Rating"
                            listOrder="7"
                            maxlength="255"
                            metaType="text-single"
                            name="protectionRating"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-protectionRating>
                        <field-operatingTemperature
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Operating Temperature"
                            listOrder="8"
                            maxlength="255"
                            metaType="text-single"
                            name="operatingTemperature"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-operatingTemperature>
                        <field-industrialProtocols
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Industrial Protocols"
                            listOrder="9"
                            maxlength="255"
                            metaType="text-single"
                            name="industrialProtocols"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-industrialProtocols>
                        <field-calibrationStandard
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Calibration Standard"
                            listOrder="10"
                            maxlength="255"
                            metaType="text-single"
                            name="calibrationStandard"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-calibrationStandard>
                        <field-compliance
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Compliance"
                            listOrder="11"
                            maxlength="255"
                            metaType="text-single"
                            name="compliance"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-compliance>
                        <field-reportTemplates
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Report Templates"
                            listOrder="12"
                            maxlength="255"
                            metaType="text-single"
                            name="reportTemplates"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </field-reportTemplates>
                    </items>
                </content>
            </cq:dialog>
        </model>
        <change-register jcr:primaryType="nt:unstructured"/>
    </jcr:content>
</jcr:root>
